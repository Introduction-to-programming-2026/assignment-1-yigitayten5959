#include "helpers.h"
#include <math.h>

// Convert image to grayscale
void grayscale(int height, int width, RGBTRIPLE image[height][width])
{
    for (int i = 0; i < height; i++)
    {
        for (int j = 0; j < width; j++)
        {
            // Calculate average of R, G, and B
            float average = (image[i][j].rgbtRed + image[i][j].rgbtGreen + image[i][j].rgbtBlue) / 3.0;
            int rounded = round(average);

            image[i][j].rgbtRed = rounded;
            image[i][j].rgbtGreen = rounded;
            image[i][j].rgbtBlue = rounded;
        }
    }
}

// Reflect image horizontally
void reflect(int height, int width, RGBTRIPLE image[height][width])
{
    for (int i = 0; i < height; i++)
    {
        for (int j = 0; j < width / 2; j++)
        {
            RGBTRIPLE temp = image[i][j];
            image[i][j] = image[i][width - 1 - j];
            image[i][width - 1 - j] = temp;
        }
    }
}

// Blur image
void blur(int height, int width, RGBTRIPLE image[height][width])
{
    RGBTRIPLE copy[height][width];
    for (int i = 0; i < height; i++)
    {
        for (int j = 0; j < width; j++)
        {
            copy[i][j] = image[i][j];
        }
    }

    for (int i = 0; i < height; i++)
    {
        for (int j = 0; j < width; j++)
        {
            float r_sum = 0, g_sum = 0, b_sum = 0;
            float count = 0;

            for (int di = -1; di <= 1; di++)
            {
                for (int dj = -1; dj <= 1; dj++)
                {
                    if (i + di >= 0 && i + di < height && j + dj >= 0 && j + dj < width)
                    {
                        r_sum += copy[i + di][j + dj].rgbtRed;
                        g_sum += copy[i + di][j + dj].rgbtGreen;
                        b_sum += copy[i + di][j + dj].rgbtBlue;
                        count++;
                    }
                }
            }
            image[i][j].rgbtRed = round(r_sum / count);
            image[i][j].rgbtGreen = round(g_sum / count);
            image[i][j].rgbtBlue = round(b_sum / count);
        }
    }
}

// Detect edges using Sobel operator
void edges(int height, int width, RGBTRIPLE image[height][width])
{
    // Define Sobel Kernels
    int Gx[3][3] = {{-1, 0, 1}, {-2, 0, 2}, {-1, 0, 1}};
    int Gy[3][3] = {{-1, -2, -1}, {0, 0, 0}, {1, 2, 1}};

    // Create a copy to keep original pixel data intact while processing
    RGBTRIPLE copy[height][width];
    for (int i = 0; i < height; i++)
    {
        for (int j = 0; j < width; j++)
        {
            copy[i][j] = image[i][j];
        }
    }

    for (int i = 0; i < height; i++)
    {
        for (int j = 0; j < width; j++)
        {
            // Initialize gradient sums for each color channel
            float Gx_r = 0, Gx_g = 0, Gx_b = 0;
            float Gy_r = 0, Gy_g = 0, Gy_b = 0;

            // Loop through 3x3 neighbor grid
            for (int di = -1; di <= 1; di++)
            {
                for (int dj = -1; dj <= 1; dj++)
                {
                    int ni = i + di;
                    int nj = j + dj;

                    // If neighbor is within bounds, add weighted color to sums
                    // If out of bounds, it's treated as black (0), so we just skip it
                    if (ni >= 0 && ni < height && nj >= 0 && nj < width)
                    {
                        Gx_r += Gx[di + 1][dj + 1] * copy[ni][nj].rgbtRed;
                        Gx_g += Gx[di + 1][dj + 1] * copy[ni][nj].rgbtGreen;
                        Gx_b += Gx[di + 1][dj + 1] * copy[ni][nj].rgbtBlue;

                        Gy_r += Gy[di + 1][dj + 1] * copy[ni][nj].rgbtRed;
                        Gy_g += Gy[di + 1][dj + 1] * copy[ni][nj].rgbtGreen;
                        Gy_b += Gy[di + 1][dj + 1] * copy[ni][nj].rgbtBlue;
                    }
                }
            }

            // Combine Gx and Gy using the formula: sqrt(Gx^2 + Gy^2)
            int red = round(sqrt(Gx_r * Gx_r + Gy_r * Gy_r));
            int green = round(sqrt(Gx_g * Gx_g + Gy_g * Gy_g));
            int blue = round(sqrt(Gx_b * Gx_b + Gy_b * Gy_b));

            // Cap the values at 255
            image[i][j].rgbtRed = (red > 255) ? 255 : red;
            image[i][j].rgbtGreen = (green > 255) ? 255 : green;
            image[i][j].rgbtBlue = (blue > 255) ? 255 : blue;
        }
    }
}
