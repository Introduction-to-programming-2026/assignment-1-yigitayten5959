import random

# Generate a random secret number between 1 and 10
secret_number = random.randint(1, 10)

# Set up a guesses counter
guesses_count = 0

print("I'm thinking of a number between 1 and 10.")

# Start an infinite loop that we will break when the user wins
while True:
    # Get the user's guess and convert to integer
    guess = int(input("Take a guess: "))
    guesses_count += 1

    # Check the guess
    if guess < secret_number:
        print("Too low!")
    elif guess > secret_number:
        print("Too high!")
    else:
        # If it's not higher or lower, it must be correct!
        break

# Print the congratulations message with the total number of guesses
print(f"Congratulations! You guessed the number in {guesses_count} tries.")
