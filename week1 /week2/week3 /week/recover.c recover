#include <stdint.h>
#include <stdio.h>
#include <stdlib.h>

typedef uint8_t BYTE;

// The block size for FAT file systems is typically 512 bytes
const int BLOCK_SIZE = 512;

int main(int argc, char *argv[])
{
    // 1. Validate command-line arguments
    if (argc != 2)
    {
        printf("Usage: ./recover IMAGE\n");
        return 1;
    }

    // 2. Open the memory card file for reading
    FILE *card = fopen(argv[1], "r");
    if (card == NULL)
    {
        printf("Could not open %s.\n", argv[1]);
        return 1;
    }

    // 3. Declare variables
    BYTE buffer[BLOCK_SIZE];   // Buffer to store a 512-byte block
    int count = 0;             // Counter for the number of JPEGs found
    FILE *img = NULL;          // File pointer for the current JPEG being written
    char filename[8];          // String to store "###.jpg\0" (8 characters)

    // 4. Main loop — read 512-byte blocks until the end of the file
    // fread returns the number of items successfully read
    while (fread(buffer, 1, BLOCK_SIZE, card) == BLOCK_SIZE)
    {
        // STEP A: Check if this block starts a new JPEG
        // JPEGs start with 0xff 0xd8 0xff, and the fourth byte's first 4 bits are 1110 (0xe)
        if (buffer[0] == 0xff && buffer[1] == 0xd8 && buffer[2] == 0xff && (buffer[3] & 0xf0) == 0xe0)
        {
            // STEP B: If we already have a JPEG open, close it to start the new one
            if (img != NULL)
            {
                fclose(img);
            }

            // STEP C: Create a new filename and open a new file pointer
            // %03i means: integer, 3 digits, padded with zeros (e.g., 001, 002)
            sprintf(filename, "%03i.jpg", count);
            img = fopen(filename, "w");
            count++;
        }

        // STEP D: If a JPEG file is currently open, write the block to it
        if (img != NULL)
        {
            fwrite(buffer, 1, BLOCK_SIZE, img);
        }
    }

    // 5. Cleanup: Close any remaining open file handles
    if (img != NULL)
    {
        fclose(img);
    }
    
    fclose(card);

    return 0;
}
